<header class="tm-header">
    <div id="match-status-badge" class="tm-status-badge tm-status-upcoming" data-state="upcoming">
        <!-- Inner glow ring for depth -->
        <div class="tm-badge-glow"></div>
        
        <!-- Live indicator dot container -->
        <div id="live-indicator" class="tm-live-dot" style="display:none;">
            <span class="tm-dot-core"></span>
            <span class="tm-dot-ripple"></span>
            <span class="tm-dot-ripple"></span>
            <span class="tm-dot-ripple"></span>
        </div>
        
        <!-- Status text with icon integration (Populated by JS) -->
        <span id="status-label" class="tm-status-text">
            <!-- Default SVG (Clock) -->
            <svg class="tm-status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
            </svg>
            <span class="tm-status-text-content">À venir</span>
        </span>
    </div>
</header>