<header class="tm-header-header">
    <div id="match-status-badge-header" class="tm-status-badge-header tm-status-upcoming-header" data-state="upcoming">
        <!-- Inner glow ring for depth -->
        <div class="tm-badge-glow-header"></div>
        
        <!-- Live indicator dot container -->
        <div id="live-indicator-header" class="tm-live-dot-header" style="display:none;">
            <span class="tm-dot-core-header"></span>
            <span class="tm-dot-ripple-header"></span>
            <span class="tm-dot-ripple-header"></span>
            <span class="tm-dot-ripple-header"></span>
        </div>
        
        <!-- Status text with icon integration (Populated by JS) -->
        <span id="status-label-header" class="tm-status-text-header">
            <!-- Default SVG (Clock) -->
            <svg class="tm-status-icon-header" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
            </svg>
            <span class="tm-status-text-content-header">À venir</span>
        </span>
    </div>
</header>