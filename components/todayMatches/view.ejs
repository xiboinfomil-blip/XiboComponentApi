<link rel="stylesheet" href="/assets/todayMatches/style.css?v=4.0.0">

<div id="today-matches-slider-wrapper" class="tm-wrapper">
    <div class="tm-card-container">
        <div class="tm-card-worldcup" id="main-card" data-state="upcoming">

            <!-- Background Effects -->
            <div class="tm-bg-effects">
                <div class="tm-gradient-orb tm-orb-1"></div>
                <div class="tm-gradient-orb tm-orb-2"></div>
                <div class="tm-gradient-orb tm-orb-3"></div>
                <div class="tm-mesh-gradient"></div>
                <div class="tm-noise-overlay"></div>
            </div>
            <div class="tm-glass-overlay"></div>

            <!-- Card Content -->
            <div class="tm-card-content">

                <!-- Header -->
                <header class="tm-header">
                    <div id="match-status-badge" class="tm-status-badge tm-status-upcoming">
                        <div id="live-indicator" class="tm-live-dot" style="display:none;"></div>
                        <span id="status-label">À venir</span>
                    </div>
                </header>

                <!-- Matchup Hero -->
                <section class="tm-matchup">

                    <!-- TEAM A -->
                    <div class="tm-team tm-team-a" id="team-a-container">
                        <div class="tm-crown" id="crown-a">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v2H5v-2z"/></svg>
                        </div>
                        <div class="tm-flag-wrapper">
                            <div class="tm-flag-container">
                                <div class="tm-flag-shine"></div>
                                <img id="flag-a" src="" alt="" class="tm-flag-image"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
                                <div class="tm-flag-fallback" style="display:none">A</div>
                            </div>
                        </div>
                        <div class="tm-team-name" id="name-a">Équipe A</div>
                        <div class="tm-team-score" id="score-a">-</div>
                        <div class="tm-result-badge" id="badge-a"></div>
                    </div>

                    <!-- CENTER -->
                    <div class="tm-center">
                        <div class="tm-vs-badge" id="vs-badge">
                            <span class="tm-vs-text">VS</span>
                            <svg class="tm-trophy-icon" viewBox="0 0 24 24" fill="currentColor" style="display:none">
                                <path d="M7 3v2H3v4c0 1.65 1.35 3 3 3h.72c.75 2.48 2.82 4.34 5.28 4.82V19h-3v2h8v-2h-3v-2.18c2.46-.48 4.53-2.34 5.28-4.82H18c1.65 0 3-1.35 3-3V5h-4V3H7zm0 7c-1.1 0-2-.9-2-2V6h2v4zm12-2c0 1.1-.9 2-2 2V6h2v4z"/>
                            </svg>
                        </div>

                        <!-- Single unified DRAW ribbon -->
                        <div class="tm-draw-ribbon" id="draw-ribbon">
                            <span class="tm-draw-line"></span>
                            <span class="tm-draw-text">MATCH NUL</span>
                            <span class="tm-draw-line"></span>
                        </div>

                        <div id="match-timer" class="tm-timer">--:--</div>
                    </div>

                    <!-- TEAM B -->
                    <div class="tm-team tm-team-b" id="team-b-container">
                        <div class="tm-crown" id="crown-b">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v2H5v-2z"/></svg>
                        </div>
                        <div class="tm-flag-wrapper">
                            <div class="tm-flag-container">
                                <div class="tm-flag-shine"></div>
                                <img id="flag-b" src="" alt="" class="tm-flag-image"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
                                <div class="tm-flag-fallback" style="display:none">B</div>
                            </div>
                        </div>
                        <div class="tm-team-name" id="name-b">Équipe B</div>
                        <div class="tm-team-score" id="score-b">-</div>
                        <div class="tm-result-badge" id="badge-b"></div>
                    </div>

                </section>

                <!-- Footer -->
                <footer class="tm-footer">
                    <div class="tm-date">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        <span id="match-date-display">Lundi, 22 Juin 2026</span>
                    </div>
                </footer>

            </div>
        </div>
    </div>
</div>

<script>
    window.TODAY_MATCHES_CONFIG = {
        sliderSpeed: <%= typeof sliderSpeed !== 'undefined' ? sliderSpeed : 8000 %>
    };
</script>
<script src="/assets/todayMatches/script.js?v=4.0.0"></script>