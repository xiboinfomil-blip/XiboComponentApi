<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700;800;900&display=swap" rel="stylesheet">
    
    <script src="/assets/global/helpers/configHelper.js?v=<%= Version %>"></script>

    <link rel="stylesheet" href="/assets/<%= componentName %>/style.css?v=<%= Version %>">
    
    <link rel="stylesheet" href="/assets/<%= componentName %>/partial-header.css?v=<%= Version %>">
    <link rel="stylesheet" href="/assets/<%= componentName %>/partial-matchup.css?v=<%= Version %>">
    <link rel="stylesheet" href="/assets/<%= componentName %>/partial-footer.css?v=<%= Version %>">
</head>
<body style="background: transparent; margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; height: 100vh; width: 100vw; overflow: hidden;">
    
    <div id="today-matches-slider-wrapper-main" class="tm-wrapper-main">
        <div class="tm-card-container-main">
            <div class="tm-card-worldcup-main" id="main-card-main" data-state="upcoming">

                <div class="tm-bg-effects-main">
                    <div class="tm-gradient-orb-main tm-orb-1-main"></div>
                    <div class="tm-gradient-orb-main tm-orb-2-main"></div>
                    <div class="tm-gradient-orb-main tm-orb-3-main"></div>
                    <div class="tm-mesh-gradient-main"></div>
                    <div class="tm-noise-overlay-main"></div>
                </div>
                <div class="tm-glass-overlay-main"></div>

                <div class="tm-card-content-main">
                    <%- include('partials/header/view') %>

                    <%- include('partials/matchup/view') %>

                    <%- include('partials/footer/view') %>
                </div>

            </div>
        </div>
    </div>

    <script src="/assets/<%= componentName %>/script.js?v=<%= Version %>"></script>
    
    <script src="/assets/<%= componentName %>/partial-matchup.js?v=<%= Version %>"></script>
</body>
</html>