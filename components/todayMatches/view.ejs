<link rel="stylesheet" href="/assets/todayMatches/style.css?v=3.1.0">
<div id="today-matches-slider-wrapper" class="tm-wrapper">
    <div class="tm-card-container">
        <div class="tm-card-worldcup" id="main-card">
            <!-- Enhanced Background Effects -->
            <div class="tm-bg-effects">
                <div class="tm-gradient-orb tm-orb-1"></div>
                <div class="tm-gradient-orb tm-orb-2"></div>
                <div class="tm-gradient-orb tm-orb-3"></div>
                <div class="tm-gradient-orb tm-orb-4"></div>
                <div class="tm-mesh-gradient"></div>
                <div class="tm-noise-overlay"></div>
            </div>
            
            <!-- Glass Overlay -->
            <div class="tm-glass-overlay"></div>
            
            <!-- Card Content -->
            <div class="tm-card-content">

                <!-- Header with Status -->
                <div class="tm-card-header">
                    <div id="match-status-badge" class="tm-status-badge tm-status-upcoming">
                        <div id="live-indicator" class="tm-live-dot" style="display: none;"></div>
                        <span id="status-label">À venir</span>
                    </div>
                </div>

                <!-- Matchup -->
                <div class="tm-matchup-container">
                    <!-- Team A -->
                    <div class="tm-team" id="team-a-container">
                        <div class="tm-flag-wrapper">
                            <div class="tm-flag-container">
                                <div class="tm-flag-shine"></div>
                                <img id="flag-a" src="" alt="Drapeau A" class="tm-flag-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
                                <div class="tm-flag-fallback" style="display:none">A</div>
                            </div>
                        </div>
                        <div class="tm-team-name" id="name-a">Équipe A</div>
                        <div class="tm-team-score" id="score-a">-</div>
                        <div class="tm-result-badge" id="badge-a" style="display: none;"></div>
                    </div>

                    <!-- Center Display -->
                    <div class="tm-center-display">
                        <div class="tm-vs-badge">
                            <span>VS</span>
                        </div>
                        <div id="match-timer" class="tm-dynamic-time">--:--</div>
                    </div>

                    <!-- Team B -->
                    <div class="tm-team" id="team-b-container">
                        <div class="tm-flag-wrapper">
                            <div class="tm-flag-container">
                                <div class="tm-flag-shine"></div>
                                <img id="flag-b" src="" alt="Drapeau B" class="tm-flag-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
                                <div class="tm-flag-fallback" style="display:none">B</div>
                            </div>
                        </div>
                        <div class="tm-team-name" id="name-b">Équipe B</div>
                        <div class="tm-team-score" id="score-b">-</div>
                        <div class="tm-result-badge" id="badge-b" style="display: none;"></div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="tm-card-footer">
                    <div class="tm-match-date">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        <span id="match-date-display">Lundi, 22 Juin 2026</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.TODAY_MATCHES_CONFIG = {
        sliderSpeed: <%= typeof sliderSpeed !== 'undefined' ? sliderSpeed : 8000 %>
    };
</script>
<script src="/assets/todayMatches/script.js?v=3.1.0"></script>