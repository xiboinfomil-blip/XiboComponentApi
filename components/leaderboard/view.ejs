<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Component specific CSS -->
    <link rel="stylesheet" href="/assets/leaderboard/style.css?v=4.1.0">
</head>
<body style="background: transparent; margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; height: 100vh; width: 100vw; overflow: hidden;">
    
    <div id="leaderboard-container" style="width: 100%; height: 100%; max-width: 100%; max-height: 100%;">
        <div class="ambient-glow"></div>
        
        <div class="leaderboard-header">
            <h2 class="leaderboard-title">Classement Pronostics</h2>
            <p class="leaderboard-subtitle">TOP 10</p>
        </div>
        
        <div id="podium-section" class="podium-container"></div>

        <div class="table-wrapper" id="scroll-wrapper">
            <table>
                <thead>
                    <tr>
                        <th style="width: 15%">Rang</th>
                        <th style="width: 60%">Nom</th>
                        <th class="col-right" style="width: 25%">Points</th>
                    </tr>
                </thead>
                <tbody id="table-body">
                    <tr id="loading-row">
                        <td colspan="3" class="loading-status">
                            <div class="empty-state">
                                <div class="loading-spinner"></div>
                                <div class="empty-text">Chargement des données...</div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- 1. Load GLOBAL Config Helper -->
    <script src="/assets/global/helpers/configHelper.js?v=1.0.0"></script>
    
    <!-- 2. Load Component Script -->
    <script src="/assets/leaderboard/script.js?v=4.1.0"></script>
</body>
</html>